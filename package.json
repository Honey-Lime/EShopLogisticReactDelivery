{
  "name": "eshoplogistic-react",
  "version": "1.0.16",
  "description": "React-компонент выбора доставки EShopLogistic и серверная функция создания заказа.",
  "type": "module",
  "main": "./dist/eshoplogistic-react.cjs",
  "module": "./dist/eshoplogistic-react.es.js",
  "exports": {
    ".": {
      "import": "./dist/eshoplogistic-react.es.js",
      "require": "./dist/eshoplogistic-react.cjs"
    },
    "./client": {
      "import": "./dist/eshoplogistic-react.es.js",
      "require": "./dist/eshoplogistic-react.cjs"
    },
    "./server": {
      "import": "./createOrder.js",
      "require": "./server.cjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "createOrder.js",
    "server.cjs",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.js",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "react-dadata": "^2.28.0-beta.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "eshoplogistic",
    "delivery",
    "react"
  ],
  "license": "MIT"
}
