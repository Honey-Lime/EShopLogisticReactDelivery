{
  "name": "eshoplogistic-react",
  "version": "1.0.10",
  "description": "React-компонент выбора доставки EShopLogistic и серверная функция создания заказа.",
  "type": "module",
  "main": "./index.cjs",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs"
    },
    "./client": "./client.js",
    "./server": {
      "import": "./createOrder.js",
      "require": "./server.cjs"
    },
    "./styles.css": "./EShopLogistic.css"
  },
  "files": [
    "index.js",
    "index.cjs",
    "client.js",
    "server.cjs",
    "EShopLogistic.jsx",
    "EShopLogistic.css",
    "createOrder.js",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "react-dadata-box": "^1.3.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "eshoplogistic",
    "delivery",
    "react"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "vite": "^8.1.5"
  }
}
